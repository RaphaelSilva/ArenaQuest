# Local development environment variables template.
# Copy this file to .dev.vars and fill in your own values.
# NEVER commit .dev.vars — it is listed in .gitignore.

JWT_SECRET=local-dev-only-secret-replace-in-staging-and-prod

# CORS — accepted origins (comma-separated).
# For local development, you can use the exact origin below.
ALLOWED_ORIGINS=http://localhost:3000
# Wildcard form (for testing pattern matching locally — dev-only, never for production):
# ALLOWED_ORIGINS=*

# R2 credentials for local dev — replace with real values from Cloudflare dashboard
R2_ACCESS_KEY_ID=local-dev-r2-access-key-id
R2_SECRET_ACCESS_KEY=local-dev-r2-secret-access-key

# MAIL_DRIVER=console writes the activation email to Wrangler stdout so devs
# can copy the link without configuring SMTP/Resend locally.
MAIL_DRIVER=
MAIL_FROM=ArenaQuest Local <noreply@arenaquest.local>
# Required when MAIL_DRIVER=resend (staging/prod use this).
RESEND_API_KEY=
# Activation and password-reset links land on this host: <WEB_BASE_URL>/activate?token=...
# Also used as the OAuth post-login redirect base: <WEB_BASE_URL>/auth/callback
WEB_BASE_URL=http://localhost:3000

# Google OAuth credentials (Task 07 — see docs/product/milestones/6/google-oauth-setup.md)
# Create an OAuth 2.0 Web Application client in Google Cloud Console, then copy:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match one of the Authorised Redirect URIs configured in the Google Console.
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback
