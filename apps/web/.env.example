# Bare origin of the ArenaQuest API Worker — no trailing slash, no path segment.
# The /v1 version prefix is injected automatically by api-client.ts; never include
# it here or requests will double-prefix (/v1/v1/...).
# Development: wrangler dev runs on http://localhost:8787
# Staging/Production: deployed Worker URL (e.g. https://api.arenaquest.app)
NEXT_PUBLIC_API_URL=http://localhost:8787

# ── White-label branding (build-time; unset → ArenaQuest defaults) ─────────────
# One brand per deployment, baked at build time (same mechanism as
# NEXT_PUBLIC_LANGUAGE). Leave these unset to build the stock ArenaQuest bundle.
#
# Badge text shown in the logo mark and the favicon.
NEXT_PUBLIC_BRAND_SIGLA=AQ
# Wordmark leading segment (un-accented).
NEXT_PUBLIC_BRAND_NAME_PREFIX=Arena
# Wordmark trailing segment (accent-coloured); empty → clean single-tone wordmark.
NEXT_PUBLIC_BRAND_NAME_ACCENT=Quest
# Force the "Powered by ArenaQuest" footer on (true) / off (false).
# Empty → auto: shown on customised builds, hidden on the stock build.
NEXT_PUBLIC_BRAND_POWERED_BY=
# Favicon badge colour as sRGB hex (favicon only — the on-screen palette stays
# the oklch() CSS variables). Empty → #ff8101 (mirrors --aq-accent).
NEXT_PUBLIC_BRAND_ACCENT=
